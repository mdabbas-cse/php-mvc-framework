{
  "name": "lora/core",
  "description": "A simple and efficiency PHP framework for building web application.",
  "type": "library",
  "keywords": [
    "framework",
    "php",
    "lora",
    "core",
    "mvc"
  ],
  "readme": "https://github.com/mdabbas-cse/php-mvc-framework/blob/main/README.md",
  "time": "",
  "support": {
    "issues": "https://github.com/mdabbas-cse/php-mvc-framework/issues",
    "source": "https://github.com/mdabbas-cse/php-mvc-framework",
    "wiki": "https://github.com/mdabbas-cse/php-mvc-framework/wiki"
  },
  "require": {
    "php": "^7.4.2|^8.0",
    "friendsofphp/php-cs-fixer": "^3.13",
    "phpmailer/phpmailer": "^7.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "phpstan/phpstan": "^1.10"
  },
  "license": "MIT",
  "authors": [
    {
      "name": "mdabbas-cse",
      "email": "gmabbas44@gmail.com",
      "role": "Developer"
    }
  ],
  "minimum-stability": "alpha",
  "autoload": {
    "psr-4": {
      "LaraCore\\": "./",
      "LaraCore\\Framework\\": "./framework/",
      "LaraCore\\App\\": "./app/",
      "LaraCore\\Config\\": "./config/",
      "LaraCore\\Database\\": "./database/",
      "LaraCore\\Resources\\": "./resources/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "LaraCore\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test":             "./vendor/bin/phpunit --testdox --colors=always --testsuite Unit",
    "test:unit":        "./vendor/bin/phpunit --testdox --colors=always --testsuite Unit",
    "test:integration": "./vendor/bin/phpunit --testdox --colors=always --testsuite Integration",
    "test:feature":     "./vendor/bin/phpunit --testdox --colors=always --testsuite Feature",
    "test:all":         "./vendor/bin/phpunit --testdox --colors=always",
    "fix":              "./vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php --allow-risky=yes --ansi -v",
    "cs-check":         "./vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php --dry-run --diff --allow-risky=yes --ansi -v",
    "fix-all":          "php-cs-fixer fix includes",
    "code-status":      "php-cs-fixer fix --dry-run --show-progress=dots --ansi --diff -vv ./",
    "lint":             "@php -r \"$e=0; foreach(new RecursiveIteratorIterator(new RecursiveDirectoryIterator('.')) as $f) { if($f->getExtension()==='php' && strpos($f->getPathname(),'vendor')===false) { exec('php -l '.$f->getPathname().' 2>&1',$out,$r); if($r){ echo implode(PHP_EOL,$out).PHP_EOL; $e++; } } } exit($e);\"",
    "analyse":          "./vendor/bin/phpstan analyse --configuration=phpstan.neon --error-format=table --ansi",
    "analyse-baseline": "./vendor/bin/phpstan analyse --configuration=phpstan.neon --generate-baseline=phpstan-baseline.neon --ansi",
    "quality":          ["@lint", "@fix", "@analyse", "@test:all"],
    "post-install-cmd": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
      "@php scripts/install-hooks.php"
    ]
  }
}
